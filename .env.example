PORT=3000
TEST_SERVER_PORT=4000
TEST_CLIENT_BASE_URL=http://localhost:3000
AUTH_WORKER_BASE_URL=http://localhost:8787

TEST_REDIRECT_URIS=http://localhost:8787/callback/test

# Optional test-client OAuth override. Leave unset to use the local mock provider
# from config/auth.config.jsonc. For Google, register this redirect URI:
# http://localhost:8787/callback/google
# OAUTH_PROVIDER_ID=google
# OAUTH_CLIENT_ID=
# OAUTH_CLIENT_SECRET=
# OAUTH_SCOPES=openid,email,profile

# Custom providers can set all endpoint fields explicitly.
# OAUTH_PROVIDER_NAME=
# OAUTH_AUTHORIZATION_ENDPOINT=
# OAUTH_TOKEN_ENDPOINT=
# OAUTH_USERINFO_ENDPOINT=

TEST_USER_SUB=test-user-1
TEST_USER_NAME=OAuth Test User
TEST_USER_EMAIL=test-user@ensombl.local
