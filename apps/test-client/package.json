{
  "name": "@ensombl/oauth-test-client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @ensombl/auth-config build && tsc -p tsconfig.json",
    "dev": "pnpm --filter @ensombl/auth-config build && tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "pnpm --filter @ensombl/auth-config build && vitest run",
    "coverage": "pnpm --filter @ensombl/auth-config build && vitest run --coverage",
    "typecheck": "pnpm --filter @ensombl/auth-config build && tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@ensombl/auth-config": "workspace:*",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "~4.1.8"
  }
}
